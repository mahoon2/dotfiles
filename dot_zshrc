# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

unset ZSH
ZSH_VENDOR="$HOME/.zsh/vendor"
ZSH_OMZ="$ZSH_VENDOR/oh-my-zsh"
export EDITOR=nvim
export PAGER=less
export CUDA_DEVICE_ORDER=PCI_BUS_ID

# Keep path/fpath local to this shell. Exported FPATH from a parent zsh can make
# child shells inherit plugin paths and force compdump churn.
typeset -U path PATH fpath FPATH
typeset +x FPATH
path=(
  "$HOME/.local/bin"
  $path
)
fpath=(
  "$HOME/.zsh/completions"
)

# Host-local paths, completions, and tool hooks. Sourced before compinit so
# machine-specific fpath entries are included in the completion cache.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

autoload -Uz compinit
_zcompdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${HOST}-${ZSH_VERSION}"
mkdir -p -- "${_zcompdump:h}"
if [[ -n "${_zcompdump}(#qNmh-24)" ]]; then
  compinit -C -d "$_zcompdump"
else
  compinit -d "$_zcompdump"
fi
unset _zcompdump

# Directly load the OMZ plugin files whose aliases/functions are part of the
# daily interface, without loading the OMZ framework itself.
if [[ -d "$ZSH_OMZ" ]]; then
  [[ -r "$ZSH_OMZ/lib/git.zsh" ]] && source "$ZSH_OMZ/lib/git.zsh"
  _git_plugin="$ZSH_OMZ/plugins/git/git.plugin.zsh"
  _git_plugin_cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/omz-git.plugin.zsh"
  if [[ -r "$_git_plugin" ]]; then
    mkdir -p -- "${_git_plugin_cache:h}"
    _git_bin="${commands[git]:-}"
    if [[ ! -s "$_git_plugin_cache" || "$_git_plugin" -nt "$_git_plugin_cache" || -n "$_git_bin" && "$_git_bin" -nt "$_git_plugin_cache" ]]; then
      _git_version="${${(As: :)$(git version 2>/dev/null)}[3]}"
      {
        while IFS= read -r _git_plugin_line; do
          case "$_git_plugin_line" in
            'git_version='*) print -r -- "git_version='$_git_version'" ;;
            *) print -r -- "$_git_plugin_line" ;;
          esac
        done < "$_git_plugin"
      } >| "$_git_plugin_cache"
      unset _git_plugin_line _git_version
    fi
    source "$_git_plugin_cache"
    unset _git_bin
  fi
  unset _git_plugin _git_plugin_cache
  _git_commit_plugin="$ZSH_OMZ/plugins/git-commit/git-commit.plugin.zsh"
  _git_commit_cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/omz-git-commit-aliases"
  if [[ -r "$_git_commit_plugin" ]]; then
    mkdir -p -- "${_git_commit_cache:h}"
    if [[ ! -s "$_git_commit_cache" || "$_git_commit_plugin" -nt "$_git_commit_cache" ]]; then
      source "$_git_commit_plugin" && print -r -- cached >| "$_git_commit_cache"
    fi
  fi
  unset _git_commit_plugin _git_commit_cache
  [[ -r "$ZSH_OMZ/plugins/tmux/tmux.plugin.zsh" ]] && source "$ZSH_OMZ/plugins/tmux/tmux.plugin.zsh"
  [[ -r "$ZSH_OMZ/plugins/virtualenv/virtualenv.plugin.zsh" ]] && source "$ZSH_OMZ/plugins/virtualenv/virtualenv.plugin.zsh"
  [[ -r "$ZSH_OMZ/plugins/colored-man-pages/colored-man-pages.plugin.zsh" ]] && source "$ZSH_OMZ/plugins/colored-man-pages/colored-man-pages.plugin.zsh"
fi

[[ -r "$ZSH_VENDOR/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && source "$ZSH_VENDOR/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
[[ -r "$ZSH_VENDOR/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]] && source "$ZSH_VENDOR/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"

if [[ -o interactive && -t 0 && -t 1 ]] && (( $+commands[fzf] )); then
  eval "$(fzf --zsh)"
fi

[[ -r "$HOME/.zsh/aliases.zsh" ]] && source "$HOME/.zsh/aliases.zsh"
unset PYTHONPATH

# Add ~/.local/bin to PATH.
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  path=("$HOME/.local/bin" $path)
fi

# Node.js (lazy-loaded; nvm itself only loads on first invocation). The
# version-pinned PATH entry lives in ~/.zshrc.local because the installed node
# version may differ across hosts.
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm node npm npx
  [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
  [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"
  nvm "$@"
}
node() { nvm >/dev/null; node "$@"; }
npm()  { nvm >/dev/null; npm  "$@"; }
npx()  { nvm >/dev/null; npx  "$@"; }

# Claude Code
path=("$HOME/.claude/local" $path)
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=yes

# Go
export GOPATH="$HOME/go"
path=("$HOME/.local/go/bin" "$GOPATH/bin" $path)

if [[ -o interactive ]]; then
  if [[ -t 0 && -t 1 ]]; then
    [[ -r "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme" ]] && source "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme"
    [[ -r "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"
  else
    {
      [[ -r "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme" ]] && source "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme"
      [[ -r "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"
    } >/dev/null 2>&1
  fi
fi
