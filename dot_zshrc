# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"
# alias ls="ls -tlh --color=tty"
alias ls="eza -l --icons=\"auto\" --group-directories-first"
alias vi="nvim"

# Python aliases
alias python="python3"
alias pip="pip3"
alias pi="pip3 install"
alias pui="pip3 uninstall"

# Python venv aliases
alias va='source .venv/bin/activate'
alias vda='deactivate'

# Conda aliases
alias ca="conda activate"
alias cda="conda deactivate"
alias ci="conda install"
alias cui="conda uninstall"
alias cls="conda list"
alias cels="conda env list"
unset PYTHONPATH

# CLI tools
alias cc="claude"
alias ccu="ccusage"
alias gem="gemini"
alias co="codex"

# Git aliases
alias gfp="git fetch --prune"

# -------------------------- #
# Locally installed packages #
# -------------------------- #

# Add ~/.local/bin to PATH
if [ -z "$(echo ":$PATH:" | grep -F ":$HOME/.local/bin:")" ]; then
	export PATH="$HOME/.local/bin:$PATH"
fi

# Node.js (lazy-loaded; nvm itself only loads on first invocation — saves ~330 ms
# per shell). The version-pinned PATH entry lives in ~/.zshrc.local because the
# installed node version may differ across hosts.
export NVM_DIR="$HOME/.nvm"
nvm() {
    unset -f nvm node npm npx
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    nvm "$@"
}
node() { nvm >/dev/null; node "$@"; }
npm()  { nvm >/dev/null; npm  "$@"; }
npx()  { nvm >/dev/null; npx  "$@"; }

# Claude Code (CC)
export PATH="$HOME/.claude/local:$PATH"
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=yes

# Go
export GOPATH="$HOME/go"
export PATH="$HOME/.local/go/bin:$GOPATH/bin:$PATH"

# Host-local overrides: credentials, cluster paths, conda, modules, perl/meme/texlive,
# pinned node version. Kept out of chezmoi; permissions are 0600.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
