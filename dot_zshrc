# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

unset ZSH
ZSH_VENDOR="$HOME/.zsh/vendor"
ZSH_OMZ="$ZSH_VENDOR/oh-my-zsh"

HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt sharehistory appendhistory extendedhistory histignoredups histreduceblanks
setopt autocd

# Keep path/fpath local to this shell. Exported FPATH from a parent zsh can make
# child shells inherit plugin paths and force compdump churn.
typeset -U path PATH fpath FPATH
typeset +x FPATH
fpath=(
  "$HOME/.zsh/completions"
  $fpath
)

# Host-local paths, completions, and tool hooks. Sourced before compinit so
# machine-specific fpath entries are included in the completion cache.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

autoload -Uz compinit
_zcompdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${HOST}-${ZSH_VERSION}"
mkdir -p -- "${_zcompdump:h}"
if [[ -n "${_zcompdump}(#qNmh-24)" ]]; then
  compinit -C -d "$_zcompdump"
else
  compinit -d "$_zcompdump"
fi
unset _zcompdump

# Load selected Oh My Zsh plugins directly without bootstrapping the OMZ
# framework. Git aliases live in ~/.zsh/aliases.zsh to keep startup cheap.
if [[ -d "$ZSH_OMZ" ]]; then
  for _omz_plugin in tmux virtualenv colored-man-pages; do
    _omz_file="$ZSH_OMZ/plugins/$_omz_plugin/$_omz_plugin.plugin.zsh"
    [[ -r "$_omz_file" ]] && source "$_omz_file"
  done
  unset _omz_plugin _omz_file
fi

# A git-installed fzf lives in ~/.fzf/bin; put it on PATH before the fzf shell
# integration below, whose $+commands[fzf] guard needs fzf to be resolvable.
[[ -x "$HOME/.fzf/bin/fzf" ]] && path=("$HOME/.fzf/bin" $path)
if [[ -o interactive ]] && (( $+commands[fzf] )); then
  _fzf_zsh_integration="$(fzf --zsh 2>/dev/null)"
  if [[ -n "$_fzf_zsh_integration" ]]; then
    if [[ -t 0 ]]; then
      eval "$_fzf_zsh_integration"
    else
      eval "$_fzf_zsh_integration" 2>/dev/null
    fi
  fi
  unset _fzf_zsh_integration
fi

[[ -r "$ZSH_VENDOR/plugins/fzf-tab/fzf-tab.plugin.zsh" ]] && source "$ZSH_VENDOR/plugins/fzf-tab/fzf-tab.plugin.zsh"
[[ -r "$ZSH_VENDOR/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && source "$ZSH_VENDOR/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh"
[[ -r "$ZSH_VENDOR/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]] && source "$ZSH_VENDOR/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"

[[ -r "$HOME/.zsh/aliases.zsh" ]] && source "$HOME/.zsh/aliases.zsh"
unset PYTHONPATH

# Node.js (lazy-loaded; nvm itself only loads on first invocation). The
# version-pinned PATH entry lives in ~/.zshrc.local because the installed node
# version may differ across hosts.
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm node npm npx
  [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
  [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"
  nvm "$@"
}
node() { nvm >/dev/null; node "$@"; }
npm()  { nvm >/dev/null; npm  "$@"; }
npx()  { nvm >/dev/null; npx  "$@"; }

# Load p10k theme manually
if [[ -o interactive ]]; then
  if [[ -t 0 && -t 1 ]]; then
    [[ -r "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme" ]] && source "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme"
    [[ -r "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"
  else
    {
      [[ -r "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme" ]] && source "$ZSH_VENDOR/themes/powerlevel10k/powerlevel10k.zsh-theme"
      [[ -r "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"
    } >/dev/null 2>&1
  fi
fi

bindkey -M viins '^A' beginning-of-line
bindkey -M viins '^E' end-of-line
bindkey -M viins '^[b' backward-word
bindkey -M viins '^[f' forward-word
bindkey -M viins '^U' backward-kill-line
bindkey -M viins '^[^?' backward-kill-word
