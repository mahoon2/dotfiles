# Files intentionally NOT managed by chezmoi.
# This file tells chezmoi to skip them during `apply`.

# Host-local zsh overrides (credentials + filesystem-dependent paths).
# Kept at ~/.zshrc.local with mode 0600 on each machine. Never commit.
.zshrc.local

# 2FA TOTP secret
.google_authenticator

# Shell / tool history (private to each machine)
.zsh_history
.bash_history
.python_history
.viminfo
.lesshst
.wget-hsts

# Generated completion / state caches (regenerated by run_once + refresh.sh)
.zcompdump*
.cache/conda-hook.zsh
.cache/p10k-instant-prompt-*

# Claude Code state (large, machine-specific)
.claude.json
.claude.json.backup

# Repo-level documentation (lives in the source dir, not deployed to $HOME)
README.md

# lazy.nvim plugin lockfile — intentionally per-host. Each machine runs
# `:Lazy update` independently, so syncing this file would create constant
# churn. Plugin specs in lua/plugins/* are the shared source of truth.
.config/nvim/lazy-lock.json
